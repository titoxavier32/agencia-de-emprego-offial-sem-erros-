<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card shadow border-0">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Meu Perfil</h4>
      </div>
      <div class="card-body">
        <div class="row align-items-center mb-4">
          <div class="col-auto">
            <% if (user.avatar) { %>
              <img src="<%= user.avatar %>" alt="Avatar" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;">
            <% } else { %>
              <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 100px; height: 100px;">
                <i class="fas fa-user fa-3x"></i>
              </div>
            <% } %>
          </div>
          <div class="col">
            <h2 class="mb-1"><%= user.name %></h2>
            <p class="text-muted mb-0"><%= user.email %></p>
            <span class="badge bg-<%= user.role === 'admin' ? 'danger' : 'info' %> mt-2"><%= user.role.toUpperCase() %></span>
          </div>
        </div>
        <hr>
        <h5 class="mb-3">Dados da Conta</h5>
        <p><strong>Cadastrado em:</strong> <%= new Date(user.createdAt).toLocaleDateString() %></p>
        <% if (user.googleId) { %>
           <p class="text-success"><i class="fab fa-google"></i> Conta vinculada ao Google</p>
        <% } %>
        <div class="d-flex justify-content-end mt-4">
           <% if (user.role === 'admin') { %>
             <a href="/admin/dashboard" class="btn btn-outline-primary me-2">Ir para o Painel Admin</a>
           <% } %>
           <a href="/auth/logout" class="btn btn-danger">Sair do Sistema</a>
        </div>
      </div>
    </div>
  </div>
</div>
