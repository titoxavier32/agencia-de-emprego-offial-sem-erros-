<%
  const formatDateBr = (value) => value ? new Date(value + 'T00:00:00').toLocaleDateString('pt-BR') : '';
  const getDisplaySchedule = (start, end) => {
    const startFormatted = formatDateBr(start);
    const endFormatted = formatDateBr(end);
    if (!startFormatted && !endFormatted) return null;
    if (startFormatted && endFormatted && startFormatted !== endFormatted) {
      return { label: 'Inscrições', value: `${startFormatted} a ${endFormatted}` };
    }
    return { label: 'Inscrição', value: startFormatted || endFormatted };
  };
%>
<section class="site-hero">
  <div class="site-hero-content">
    <span class="site-kicker">Concursos e processos seletivos</span>
    <h1>Divulgue editais públicos com mais estrutura, credibilidade e leitura objetiva.</h1>
    <p class="site-lead">A plataforma agora também organiza seleções públicas com dados do edital, período de inscrição, cronograma e quadro de cargos.</p>
  </div>
</section>

<section class="site-section">
  <div class="site-page-header">
    <div>
      <h1>Seleções públicas em destaque</h1>
      <p class="site-page-copy">Acompanhe concursos públicos e processos seletivos publicados na plataforma.</p>
    </div>
  </div>

  <% if (publicSelections.length > 0) { %>
    <div class="site-card-grid">
      <% publicSelections.forEach(item => { const selectionSchedule = getDisplaySchedule(item.registrationStartDate, item.registrationEndDate); %>
        <article class="site-card" data-preview-item data-preview-badge="<%= item.category === 'concurso_publico' ? 'Concurso' : 'Processo seletivo' %>" data-preview-title="<%= item.title %>" data-preview-description="<%= (item.description || '').replace(/\"/g, '&quot;') %>" data-preview-image="<%= item.image ? '/uploads/' + item.image : '' %>" data-preview-meta-label="Situação" data-preview-meta-value="<%= item.status || 'Publicado' %>" data-preview-period="<%= selectionSchedule ? selectionSchedule.value : '' %>" data-preview-period-label="<%= selectionSchedule ? selectionSchedule.label : 'Inscrições' %>" data-preview-link="<%= item.noticePdf ? '/uploads/' + item.noticePdf : '/selecoes-publicas/' + item.id %>" data-preview-link-label="<%= item.noticePdf ? 'Ver edital completo' : 'Ver detalhes' %>" data-preview-link-target="<%= item.noticePdf ? '_blank' : '' %>">
          <div class="site-card-media" data-open-preview role="button" tabindex="0" aria-label="Visualizar seleção pública">
            <% if (item.image) { %>
              <img src="/uploads/<%= item.image %>" alt="<%= item.title %>">
            <% } else { %>
              <div class="site-card-icon"><i class="fas fa-file-signature"></i></div>
            <% } %>
            <span class="site-card-badge -accent"><%= item.category === 'concurso_publico' ? 'Concurso' : 'Processo seletivo' %></span>
          </div>
          <div class="site-card-body">
            <h3><%= item.title %></h3>
            <p class="site-card-text"><%= (item.description || '').length > 170 ? item.description.substring(0, 170) + '...' : (item.description || '') %></p>
            <div class="site-detail-list">
              <% if (item.processNumber) { %><span><strong>Processo:</strong> <%= item.processNumber %></span><% } %>
              <% if (item.status) { %><span><strong>Situação:</strong> <%= item.status %></span><% } %>
              <% if (selectionSchedule) { %><span><strong><%= selectionSchedule.label %>:</strong> <%= selectionSchedule.value %></span><% } %>
              <% if (item.noticePdf) { %><span><strong>Edital:</strong> PDF anexado</span><% } %>
            </div>
            <div class="site-card-meta">
              <span>Publicado em <%= new Date(item.createdAt).toLocaleDateString('pt-BR') %></span>
              <button type="button" class="site-button" data-open-preview>Visualizar</button>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <div class="site-empty">
      <i class="fas fa-file-signature"></i>
      <p>Nenhuma seleção pública cadastrada.</p>
    </div>
  <% } %>
</section>
