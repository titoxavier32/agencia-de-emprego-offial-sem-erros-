<div class="admin-page">
  <section class="admin-form-wrap">
    <div class="admin-section-head">
      <div>
        <h2><%= title %></h2>
        <p>Gerencie banners com grupo, posição, tamanho livre e ordem de exibição.</p>
      </div>
      <a href="/admin/propagandas" class="admin-btn-ghost">Voltar</a>
    </div>

    <% if (typeof formError !== 'undefined' && formError) { %>
      <div class="admin-alert"><%= formError %></div>
    <% } %>

    <form action="<%= advertisement ? '/admin/propagandas/editar/' + advertisement.id : '/admin/propagandas/nova' %>" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="placement">Local de exibição</label>
          <select id="placement" name="placement">
            <option value="hero_top" <%= advertisement && advertisement.placement === 'hero_top' ? 'selected' : '' %>>Acima da plataforma profissional</option>
            <option value="mural_home" <%= !advertisement || advertisement.placement === 'mural_home' ? 'selected' : '' %>>Mural publicitário da home</option>
          </select>
          <div class="admin-help">Cada área mostra até 3 quadros por vez, em 3 colunas e 1 linha.</div>
        </div>

        <div class="admin-form-row">
          <label for="groupName">Grupo</label>
          <input type="text" id="groupName" name="groupName" value="<%= advertisement ? (advertisement.groupName || 'Geral') : 'Geral' %>" placeholder="Ex.: Grupo 1, Campanha principal, Lateral">
          <div class="admin-help">Use o grupo para separar os banners que você quer gerenciar juntos.</div>
        </div>
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="image">Imagem animada ou estática <span class="admin-help"><%= advertisement ? '(opcional na edição)' : '(obrigatória)' %></span></label>
          <input type="file" id="image" name="image" accept="image/png,image/jpeg,image/jpg,image/gif,image/webp" <%= advertisement ? '' : 'required' %>>
          <div class="admin-help">Aceita PNG, JPEG, JPG, GIF e WEBP com até 50 MB.</div>
        </div>

        <div class="admin-form-row">
          <label for="position">Posição no grupo</label>
          <input type="number" id="position" name="position" min="1" max="999" value="<%= advertisement ? (advertisement.position || 1) : 1 %>">
          <div class="admin-help">Esta posição define a ordem principal do banner dentro do grupo.</div>
        </div>
      </div>

      <div class="admin-form-row">
        <label for="title">Título interno da propaganda <span class="admin-help">(opcional)</span></label>
        <input type="text" id="title" name="title" value="<%= advertisement ? advertisement.title : '' %>" placeholder="Use apenas para identificar no painel administrativo">
        <div class="admin-help">Este título não aparece no site. Ele serve apenas para organização no modo administrador.</div>
      </div>

      <div class="admin-form-row">
        <label for="description">Descrição interna <span class="admin-help">(opcional)</span></label>
        <textarea id="description" name="description" placeholder="Observação opcional para sua organização no painel"><%= advertisement ? advertisement.description : '' %></textarea>
        <div class="admin-help">Use este campo como observação administrativa. O banner público prioriza a imagem.</div>
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="link">Link ao clicar <span class="admin-help">(opcional)</span></label>
          <input type="url" id="link" name="link" value="<%= advertisement ? advertisement.link : '' %>" placeholder="https://seusite.com">
        </div>

        <div class="admin-form-row">
          <label for="animation">Animação <span class="admin-help">(opcional)</span></label>
          <select id="animation" name="animation">
            <option value="pulse" <%= !advertisement || advertisement.animation === 'pulse' ? 'selected' : '' %>>Pulse</option>
            <option value="float" <%= advertisement && advertisement.animation === 'float' ? 'selected' : '' %>>Float</option>
            <option value="glow" <%= advertisement && advertisement.animation === 'glow' ? 'selected' : '' %>>Glow</option>
            <option value="zoom" <%= advertisement && advertisement.animation === 'zoom' ? 'selected' : '' %>>Zoom</option>
            <option value="none" <%= advertisement && advertisement.animation === 'none' ? 'selected' : '' %>>Sem animação</option>
          </select>
        </div>
      </div>

      <div class="admin-form-grid admin-form-grid-3">
        <div class="admin-form-row">
          <label for="width">Largura em pixels <span class="admin-help">(opcional)</span></label>
          <input type="number" id="width" name="width" min="120" max="1600" value="<%= advertisement ? advertisement.width : 500 %>">
        </div>

        <div class="admin-form-row">
          <label for="height">Altura em pixels <span class="admin-help">(opcional)</span></label>
          <input type="number" id="height" name="height" min="80" max="1200" value="<%= advertisement ? advertisement.height : 105 %>">
        </div>

        <div class="admin-form-row">
          <label for="order">Ordem adicional</label>
          <input type="number" id="order" name="order" min="0" max="999" value="<%= advertisement ? advertisement.order : 0 %>">
        </div>
      </div>

      <div class="admin-form-checkbox">
        <label><input type="checkbox" name="isActive" <%= !advertisement || advertisement.isActive ? 'checked' : '' %>> Exibir no site</label>
      </div>
      <div class="admin-help">Desative esta opção quando quiser manter a propaganda cadastrada no painel sem mostrar no site.</div>

      <% if (advertisement && advertisement.image) { %>
        <div class="admin-image-preview">
          <img src="/uploads/<%= advertisement.image %>" alt="Imagem atual">
        </div>
      <% } %>

      <div class="admin-help">Somente a imagem é obrigatória. Use grupo, posição e ordem para organizar exatamente como cada banner deve aparecer.</div>

      <div class="admin-actions">
        <button type="submit" class="admin-btn">Salvar propaganda</button>
      </div>
    </form>
  </section>
</div>
