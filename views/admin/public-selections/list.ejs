<div class="admin-page">
  <section class="admin-hero">
    <div class="admin-kicker">Editais e oportunidades públicas</div>
    <h1>Gerencie concursos e processos seletivos com estrutura própria.</h1>
    <p>Essa área amplia a plataforma para divulgar editais com mais profundidade, prazos e cargos detalhados.</p>
  </section>

  <section class="admin-table-wrap">
    <div class="admin-section-head">
      <div>
        <h2>Seleções públicas cadastradas</h2>
        <p>Concentre aqui concursos públicos e processos seletivos temporários.</p>
      </div>
      <a href="/admin/selecoes-publicas/nova" class="admin-btn"><i class="fas fa-plus"></i><span>Nova divulgação</span></a>
    </div>

    <% if (publicSelections.length > 0) { %>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Tipo</th>
            <th>Título</th>
            <th>Processo</th>
            <th>Inscrições</th>
            <th>Situação</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% publicSelections.forEach(item => { %>
            <tr>
              <td><span class="admin-badge neutral"><%= item.category === 'concurso_publico' ? 'Concurso' : 'Processo seletivo' %></span></td>
              <td><strong><%= item.title %></strong><div class="admin-help"><%= item.description.length > 110 ? item.description.substring(0, 110) + '...' : item.description %></div></td>
              <td><%= item.processNumber || 'Não informado' %></td>
              <td>
                <% if (item.registrationStartDate || item.registrationEndDate) { %>
                  <span class="admin-help">
                    <%= item.registrationStartDate ? new Date(item.registrationStartDate + 'T00:00:00').toLocaleDateString('pt-BR') : 'Sem início' %>
                    até
                    <%= item.registrationEndDate ? new Date(item.registrationEndDate + 'T00:00:00').toLocaleDateString('pt-BR') : 'Sem fim' %>
                  </span>
                <% } else { %>
                  <span class="admin-help">Não informado</span>
                <% } %>
              </td>
              <td><span class="admin-badge <%= item.status === 'Publicado' ? 'success' : 'warning' %>"><%= item.status || 'Sem status' %></span></td>
              <td><div class="admin-actions"><a href="/admin/selecoes-publicas/editar/<%= item.id %>" class="admin-btn-secondary">Editar</a><form action="/admin/selecoes-publicas/deletar/<%= item.id %>" method="POST" onsubmit="return confirm('Tem certeza que deseja excluir esta divulgação?');"><button type="submit" class="admin-btn-danger">Excluir</button></form></div></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <div class="admin-empty">Nenhuma seleção pública cadastrada.</div>
    <% } %>
  </section>
</div>
