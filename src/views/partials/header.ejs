<style>
  :root {
    <% const themeColor = globalSetting && globalSetting.themeColor ? globalSetting.themeColor : 'blue'; %>
    <% const hexToRgb = (hex, fallback) => {
      const normalized = String(hex || '').replace('#', '');
      if (normalized.length !== 6) return fallback;
      const r = parseInt(normalized.slice(0, 2), 16);
      const g = parseInt(normalized.slice(2, 4), 16);
      const b = parseInt(normalized.slice(4, 6), 16);
      return `${r}, ${g}, ${b}`;
    }; %>
    <% const defaultPrimaryHex = themeColor === 'black' ? '#0f172a' : (themeColor === 'pink' ? '#db2777' : '#0055ff'); %>
    <% const defaultPrimaryRgb = themeColor === 'black' ? '15, 23, 42' : (themeColor === 'pink' ? '219, 39, 119' : '0, 85, 255'); %>
    <% const primaryHex = globalSetting && globalSetting.primaryColor ? globalSetting.primaryColor : defaultPrimaryHex; %>
    <% const accentHex = globalSetting && globalSetting.accentColor ? globalSetting.accentColor : '#f97316'; %>
    <% const surfaceHex = globalSetting && globalSetting.surfaceColor ? globalSetting.surfaceColor : '#ffffff'; %>
    <% const textHex = globalSetting && globalSetting.textColor ? globalSetting.textColor : '#0f172a'; %>
    <% const mutedHex = globalSetting && globalSetting.mutedColor ? globalSetting.mutedColor : '#475569'; %>
    <% const headingHex = globalSetting && globalSetting.headingColor ? globalSetting.headingColor : '#020617'; %>
    <% const backgroundBaseHex = globalSetting && globalSetting.backgroundBaseColor ? globalSetting.backgroundBaseColor : '#f8fafc'; %>
    --site-primary: <%= primaryHex %>;
    --site-primary-rgb: <%= hexToRgb(primaryHex, defaultPrimaryRgb) %>;
    --site-accent: <%= accentHex %>;
    --site-accent-rgb: <%= hexToRgb(accentHex, '249, 115, 22') %>;
    --site-surface: <%= surfaceHex %>;
    --site-surface-soft: #f8fafc;
    --site-border: rgba(148, 163, 184, 0.22);
    --site-text: <%= textHex %>;
    --site-muted: <%= mutedHex %>;
    --site-heading: <%= headingHex %>;
    --site-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
    --site-radius-xl: 28px;
    --site-radius-lg: 20px;
    --site-radius-md: 14px;
    --site-backdrop: rgba(255, 255, 255, 0.8);
    <% if (globalSetting && globalSetting.backgroundImage) { %>
      --site-background-image: url('/uploads/<%= globalSetting.backgroundImage %>');
    <% } else { %>
      --site-background-image: none;
    <% } %>
    --site-background-base: <%= backgroundBaseHex %>;
    --site-background-opacity: <%= globalSetting && globalSetting.backgroundOpacity !== undefined ? globalSetting.backgroundOpacity : 1 %>;
    --site-card-image-height: <%= globalSetting && globalSetting.cardImageHeight ? globalSetting.cardImageHeight : 220 %>px;
    --site-navbar-font-size: <%= globalSetting && globalSetting.navbarFontSize ? globalSetting.navbarFontSize : 15 %>px;
    --site-navbar-gap: <%= globalSetting && globalSetting.navbarItemGap ? globalSetting.navbarItemGap : 10 %>px;
    --site-navbar-padding-x: <%= globalSetting && globalSetting.navbarItemPaddingX ? globalSetting.navbarItemPaddingX : 16 %>px;
    --site-navbar-item-height: <%= globalSetting && globalSetting.navbarItemMinHeight ? globalSetting.navbarItemMinHeight : 44 %>px;
    --site-navbar-wrap: <%= globalSetting && globalSetting.navbarWrap ? globalSetting.navbarWrap : 'nowrap' %>;
    --site-hero-min-height: <%= globalSetting && globalSetting.heroHeight ? globalSetting.heroHeight : 0 %>px;
    --site-hero-padding: <%= globalSetting && globalSetting.heroPadding ? globalSetting.heroPadding : 42 %>px;
    --site-hero-title-size: <%= globalSetting && globalSetting.heroTitleSize ? globalSetting.heroTitleSize : 72 %>px;
    --site-hero-content-width: <%= globalSetting && globalSetting.heroContentWidth ? globalSetting.heroContentWidth : 720 %>px;
    --site-hero-kicker-size: <%= globalSetting && globalSetting.heroKickerSize ? globalSetting.heroKickerSize : 12 %>px;
    --site-hero-description-size: <%= globalSetting && globalSetting.heroDescriptionSize ? globalSetting.heroDescriptionSize : 17 %>px;
    --site-hero-text-align: <%= globalSetting && globalSetting.heroTextAlign ? globalSetting.heroTextAlign : 'left' %>;
    --site-hero-offset-x: <%= globalSetting && globalSetting.heroContentOffsetX ? globalSetting.heroContentOffsetX : 0 %>px;
    --site-hero-offset-y: <%= globalSetting && globalSetting.heroContentOffsetY ? globalSetting.heroContentOffsetY : 0 %>px;
    --site-home-hero-enabled: <%= !globalSetting || globalSetting.heroEnabled !== false ? 'block' : 'none' %>;
    --site-home-hero-max-width: <%= globalSetting && globalSetting.heroMaxWidth ? globalSetting.heroMaxWidth + 'px' : '100%' %>;
    --site-home-hero-radius: <%= globalSetting && globalSetting.heroBorderRadius ? globalSetting.heroBorderRadius : 28 %>px;
    --site-home-hero-bg: <%= globalSetting && globalSetting.heroBackgroundColor ? globalSetting.heroBackgroundColor : 'linear-gradient(135deg, rgba(15, 23, 42, 0.94), rgba(' + hexToRgb(primaryHex, defaultPrimaryRgb) + ', 0.92))' %>;
    --site-home-hero-content-bg: <%= globalSetting && globalSetting.heroContentBackgroundColor ? globalSetting.heroContentBackgroundColor : 'transparent' %>;
    --site-home-hero-text: <%= globalSetting && globalSetting.heroTextColor ? globalSetting.heroTextColor : '#ffffff' %>;
    --site-home-hero-muted: <%= globalSetting && globalSetting.heroMutedTextColor ? globalSetting.heroMutedTextColor : 'rgba(255, 255, 255, 0.82)' %>;
    --site-top-ads-offset-x: <%= globalSetting && globalSetting.topAdsOffsetX ? globalSetting.topAdsOffsetX : 0 %>px;
    --site-top-ads-offset-y: <%= globalSetting && globalSetting.topAdsOffsetY ? globalSetting.topAdsOffsetY : 0 %>px;
    --site-top-ads-max-width: <%= globalSetting && globalSetting.topAdsMaxWidth ? globalSetting.topAdsMaxWidth : 1200 %>px;
    --site-mural-ads-offset-x: <%= globalSetting && globalSetting.muralAdsOffsetX ? globalSetting.muralAdsOffsetX : 0 %>px;
    --site-mural-ads-offset-y: <%= globalSetting && globalSetting.muralAdsOffsetY ? globalSetting.muralAdsOffsetY : 0 %>px;
    --site-mural-ads-max-width: <%= globalSetting && globalSetting.muralAdsMaxWidth ? globalSetting.muralAdsMaxWidth : 1200 %>px;
    --site-preview-dialog-max-width: <%= globalSetting && globalSetting.previewDialogMaxWidth ? globalSetting.previewDialogMaxWidth : 1380 %>px;
    --site-preview-dialog-min-height: <%= globalSetting && globalSetting.previewDialogMinHeight ? globalSetting.previewDialogMinHeight : 82 %>vh;
    --site-preview-info-width: <%= globalSetting && globalSetting.previewInfoPanelWidth ? globalSetting.previewInfoPanelWidth : 380 %>px;
    --site-detail-pdf-min-height: <%= globalSetting && globalSetting.detailPdfMinHeight ? globalSetting.detailPdfMinHeight : 1200 %>px;
  }
</style>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/site-professional.css">
<% if (globalSetting && globalSetting.customCss) { %>
<style>
<%- globalSetting.customCss %>
</style>
<% } %>
<style>
  .site-detail-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 24px; }
  .site-detail-card { padding: 24px; border-radius: var(--site-radius-xl); background: rgba(255, 255, 255, 0.92); border: 1px solid var(--site-border); box-shadow: var(--site-shadow); }
  .site-detail-card h2 { margin: 0 0 16px; font-size: 1.3rem; color: var(--site-heading); }
  .site-detail-list { display: grid; gap: 10px; }
  .site-detail-list span { display: block; color: var(--site-muted); line-height: 1.7; }
  .site-detail-list strong { color: var(--site-heading); }
  .site-detail-table-wrap { overflow: auto; border-radius: var(--site-radius-xl); border: 1px solid var(--site-border); background: rgba(255, 255, 255, 0.94); box-shadow: var(--site-shadow); }
  .site-detail-table { width: 100%; min-width: 720px; border-collapse: collapse; }
  .site-detail-table th, .site-detail-table td { padding: 16px 18px; border-bottom: 1px solid rgba(148, 163, 184, 0.18); text-align: left; vertical-align: top; }
  .site-detail-table th { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--site-muted); background: rgba(248, 250, 252, 0.9); }
  @media (max-width: 1024px) {
    .site-detail-grid { grid-template-columns: 1fr; }
  }
</style>

<% if (globalSetting && globalSetting.googleAdSenseCode) { %>
  <%- globalSetting.googleAdSenseCode %>
<% } %>
