<%
  const heroActionPrimaryLabel = globalSetting && globalSetting.heroActionPrimaryLabel ? globalSetting.heroActionPrimaryLabel : 'Cadastrar currículo';
  const heroActionPrimaryLink = globalSetting && globalSetting.heroActionPrimaryLink ? globalSetting.heroActionPrimaryLink : '/acesso-candidato?section=register-candidate';
  const heroActionSecondaryLabel = globalSetting && globalSetting.heroActionSecondaryLabel ? globalSetting.heroActionSecondaryLabel : 'Explorar vagas';
  const heroActionSecondaryLink = globalSetting && globalSetting.heroActionSecondaryLink ? globalSetting.heroActionSecondaryLink : '/vagas';

  const eventSlides = (typeof featuredHeroEvents !== 'undefined' ? featuredHeroEvents : [])
    .filter((item) => item && (item.title || item.description))
    .map((item) => ({
      order: item.heroOrder || 0,
      kicker: item.heroKicker || item.category || 'Notícia em destaque',
      title: item.title,
      summary: item.heroSummary || item.description,
      image: item.image ? ('/uploads/' + item.image) : '',
      primaryLabel: item.heroButtonLabel || 'Saiba mais',
      primaryLink: item.link || '/eventos',
      secondaryLabel: heroActionSecondaryLabel,
      secondaryLink: heroActionSecondaryLink,
      meta: [item.date ? new Date(item.date + 'T00:00:00').toLocaleDateString('pt-BR') : '', item.location || ''].filter(Boolean).join(' | ')
    }));

  const publicSelectionSlides = (typeof featuredHeroPublicSelections !== 'undefined' ? featuredHeroPublicSelections : [])
    .filter((item) => item && (item.title || item.description))
    .map((item) => ({
      order: item.heroOrder || 0,
      kicker: item.heroKicker || (item.category === 'concurso_publico' ? 'Concurso em destaque' : 'Processo seletivo'),
      title: item.title,
      summary: item.heroSummary || item.description,
      image: item.image ? ('/uploads/' + item.image) : '',
      primaryLabel: item.heroButtonLabel || 'Ver edital',
      primaryLink: item.link || ('/selecoes-publicas/' + item.id),
      secondaryLabel: 'Ver concursos',
      secondaryLink: '/selecoes-publicas',
      meta: [item.sphere || '', item.region || ''].filter(Boolean).join(' | ')
    }));

  const adSlides = (typeof sliderAdvertisements !== 'undefined' ? sliderAdvertisements : [])
    .map((ad) => ({
      order: ad.order || 0,
      kicker: ad.heroKicker || 'Novidade',
      title: ad.title || 'Destaque profissional',
      summary: ad.description || '',
      image: ad.image ? ('/images/propagandas/' + ad.image) : '',
      primaryLabel: ad.heroButtonLabel || 'Saiba mais',
      primaryLink: ad.link || '#',
      secondaryLabel: heroActionPrimaryLabel,
      secondaryLink: heroActionPrimaryLink,
      meta: 'Destaque da plataforma'
    }));

  const combinedSlides = [...eventSlides, ...publicSelectionSlides, ...adSlides]
    .sort((left, right) => (left.order || 0) - (right.order || 0))
    .slice(0, 10);

  const fallbackImage = globalSetting && globalSetting.backgroundImage ? ('/uploads/' + globalSetting.backgroundImage) : '';
  const slides = combinedSlides.length > 0 ? combinedSlides : [{
    kicker: globalSetting && globalSetting.heroKicker ? globalSetting.heroKicker : 'Plataforma profissional para carreira',
    title: globalSetting && globalSetting.heroTitle ? globalSetting.heroTitle : 'Conecte talento, vagas e qualificação em uma vitrine moderna.',
    summary: globalSetting && globalSetting.heroDescription ? globalSetting.heroDescription : 'Uma plataforma pensada para divulgar oportunidades, notícias e editais com mais clareza, confiança e presença institucional.',
    image: fallbackImage,
    primaryLabel: heroActionSecondaryLabel,
    primaryLink: heroActionSecondaryLink,
    secondaryLabel: heroActionPrimaryLabel,
    secondaryLink: heroActionPrimaryLink,
    meta: 'Vagas, cursos, eventos e concursos em destaque'
  }];
%>
<section class="site-hero site-home-hero site-home-hero-carousel site-home-hero-nu" data-hero-carousel data-hero-autoplay="7000">
  <div class="site-page">
    <div class="site-home-hero-shell">
      <div class="site-home-hero-slides">
        <% slides.forEach((slide, index) => { %>
          <article class="site-home-hero-slide <%= index === 0 ? 'is-active' : '' %>" data-hero-slide aria-hidden="<%= index === 0 ? 'false' : 'true' %>">
            <div class="site-home-hero-copy">
              <div class="site-home-hero-copy-top">
                <span class="site-kicker"><%= slide.kicker %></span>
                <% if (slide.meta) { %>
                  <span class="site-home-hero-meta"><%= slide.meta %></span>
                <% } %>
              </div>

              <h1><%= slide.title %></h1>
              <p class="site-lead"><%= String(slide.summary || '').slice(0, 170) %><%= String(slide.summary || '').length > 170 ? '...' : '' %></p>

              <div class="site-home-hero-actions-row">
                <a href="<%= slide.primaryLink %>" class="site-button"><%= slide.primaryLabel %></a>
                <a href="<%= slide.secondaryLink %>" class="site-button-ghost"><%= slide.secondaryLabel %></a>
              </div>
            </div>

            <div class="site-home-hero-media">
              <% if (slide.image) { %>
                <img src="<%= slide.image %>" alt="<%= slide.title %>">
              <% } else { %>
                <div class="site-home-hero-media-fallback">
                  <span>Agência de Emprego</span>
                </div>
              <% } %>
              <div class="site-home-hero-glow"></div>
            </div>
          </article>
        <% }) %>
      </div>

      <div class="site-home-hero-footer">
        <div class="site-home-hero-caption">
          <strong>Agência de Emprego</strong>
          <span>Banner rotativo com notícias, eventos e concursos ativados no painel.</span>
        </div>

        <% if (slides.length > 1) { %>
          <div class="site-home-hero-nav">
            <button type="button" class="site-home-hero-arrow" data-hero-prev aria-label="Slide anterior"><i class="fas fa-chevron-left"></i></button>
            <div class="site-home-hero-dots">
              <% slides.forEach((slide, index) => { %>
                <button type="button" class="site-home-hero-dot <%= index === 0 ? 'is-active' : '' %>" data-hero-dot="<%= index %>" aria-label="Ir para slide <%= index + 1 %>"></button>
              <% }) %>
            </div>
            <button type="button" class="site-home-hero-arrow" data-hero-next aria-label="Próximo slide"><i class="fas fa-chevron-right"></i></button>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</section>
