<%
const categoryMeta = {
  contato_geral: { label: 'Contato geral', className: 'admin-badge category-general' },
  feedback: { label: 'Feedback', className: 'admin-badge category-feedback' },
  suporte: { label: 'Suporte', className: 'admin-badge category-support' },
  parceria_comercial: { label: 'Parceria comercial', className: 'admin-badge category-partnership' },
  divulgacao_curso: { label: 'Divulgar curso', className: 'admin-badge category-course' },
  divulgacao_vaga: { label: 'Divulgar vaga', className: 'admin-badge category-job' },
  propaganda: { label: 'Propaganda', className: 'admin-badge category-advertising' },
  institucional: { label: 'Institucional', className: 'admin-badge category-institutional' }
};
const paymentMeta = {
  pendente: { label: 'Pendente', className: 'admin-badge warning' },
  pagamento_informado: { label: 'Aguardando conferencia', className: 'admin-badge payment-review' },
  pagamento_confirmado: { label: 'Pagamento confirmado', className: 'admin-badge success' }
};
const getCategoryMeta = (value) => categoryMeta[value] || { label: value || 'Contato geral', className: 'admin-badge neutral' };
const getPaymentMeta = (value) => paymentMeta[value] || null;
%>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="admin-page" id="dashboard-content">
  <section class="admin-hero">
    <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 20px;">
      <div>
        <div class="admin-kicker">Inteligência de Dados</div>
        <h1>Visão Executiva e Performance do Portal</h1>
        <p>Acompanhe o crescimento de acessos, o nível de satisfação dos usuários e a movimentação comercial em tempo real.</p>
      </div>
      <button onclick="window.print()" class="admin-btn-premium no-print">
        <i class="fas fa-file-pdf"></i>
        <span>Exportar Relatório PDF</span>
      </button>
    </div>
  </section>

  <!-- Analytics Summary -->
  <section class="admin-stats-grid">
    <div class="admin-stat-card">
      <div class="admin-stat-icon"><i class="fas fa-eye"></i></div>
      <div class="admin-stat-info">
        <h3><%= visitCount %></h3>
        <span>Total de Visitas</span>
      </div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-icon"><i class="fas fa-star"></i></div>
      <div class="admin-stat-info">
        <h3><%= surveyCount %></h3>
        <span>Feedbacks</span>
      </div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-icon"><i class="fas fa-briefcase"></i></div>
      <div class="admin-stat-info">
        <h3><%= jobCount %></h3>
        <span>Vagas</span>
      </div>
    </div>
    <div class="admin-stat-card">
      <div class="admin-stat-icon"><i class="fas fa-envelope"></i></div>
      <div class="admin-stat-info">
        <h3><%= contactCount %></h3>
        <span>Mensagens</span>
      </div>
    </div>
  </section>

  <!-- Charts Section -->
  <section class="admin-grid two">
    <article class="admin-panel chart-panel">
      <div class="admin-section-head">
        <div>
          <h2>Tráfego de Visitas</h2>
          <p>Acompanhamento de acessos únicos nos últimos 7 dias.</p>
        </div>
      </div>
      <div class="chart-container">
        <canvas id="visitsChart"></canvas>
      </div>
    </article>

    <article class="admin-panel chart-panel">
      <div class="admin-section-head">
        <div>
          <h2>Nível de Satisfação</h2>
          <p>Distribuição de notas dadas pelos usuários.</p>
        </div>
      </div>
      <div class="chart-container">
        <canvas id="surveyChart"></canvas>
      </div>
    </article>
  </section>

  <section class="admin-grid admin-grid-three">
    <article class="admin-panel admin-panel-tone received">
      <div class="admin-kicker">Recebido</div>
      <h2 class="admin-panel-metric"><%= paymentSummary.totalReceivedLabel %></h2>
      <p>Valor já confirmado como recebido.</p>
      <div class="admin-help"><strong><%= paymentSummary.receivedCount %></strong> pagamento(s) confirmado(s)</div>
    </article>
    <article class="admin-panel admin-panel-tone pending">
      <div class="admin-kicker">Pendente</div>
      <h2 class="admin-panel-metric"><%= paymentSummary.totalPendingLabel %></h2>
      <p>Valor comercial aguardando pagamento.</p>
      <div class="admin-help"><strong><%= paymentSummary.pendingCount %></strong> pendência(s)</div>
    </article>
    <article class="admin-panel admin-panel-tone review">
      <div class="admin-kicker">Conferência</div>
      <h2 class="admin-panel-metric"><%= paymentSummary.totalUnderReviewLabel %></h2>
      <p>Pagamentos informados aguardando validação.</p>
      <div class="admin-help"><strong><%= paymentSummary.underReviewCount %></strong> em análise</div>
    </article>
  </section>

  <section class="admin-grid two">
    <article class="admin-panel">
      <div class="admin-section-head"><div><h2>Ações rápidas</h2><p>Gerenciamento direto de conteúdo.</p></div></div>
      <div class="admin-actions">
        <a href="/admin/vagas" class="admin-btn-secondary"><i class="fas fa-briefcase"></i><span>Vagas</span></a>
        <a href="/admin/candidaturas" class="admin-btn-secondary"><i class="fas fa-file-circle-check"></i><span>Candidaturas</span></a>
        <a href="/admin/usuarios" class="admin-btn-secondary"><i class="fas fa-users-cog"></i><span>Usuários</span></a>
        <a href="/admin/empresas" class="admin-btn-secondary"><i class="fas fa-building"></i><span>Empresas</span></a>
        <a href="/admin/vagas/nova" class="admin-btn"><i class="fas fa-plus"></i><span>Nova Vaga</span></a>
        <a href="/admin/cursos/novo" class="admin-btn"><i class="fas fa-plus"></i><span>Novo Curso</span></a>
        <a href="/admin/selecoes-publicas/nova" class="admin-btn"><i class="fas fa-file-circle-plus"></i><span>Nova Seleção</span></a>
        <a href="/admin/configuracoes" class="admin-btn-ghost"><i class="fas fa-sliders"></i><span>Configurações</span></a>
        <a href="/admin/estrutura-site" class="admin-btn-ghost"><i class="fas fa-diagram-project"></i><span>Mapa do Site</span></a>
      </div>
    </article>

    <article class="admin-panel">
      <div class="admin-section-head"><div><h2>Feedbacks Recentes</h2><p>Pesquisas de satisfação recebidas.</p></div></div>
      <% if (recentSurveys.length > 0) { %>
        <div style="display:grid;gap:14px;">
          <% recentSurveys.forEach(survey => { %>
            <div class="survey-list-item">
              <div class="survey-list-header">
                <div class="survey-list-stars">
                  <% for(let i=1; i<=5; i++) { %>
                    <i class="fas fa-star <%= i <= survey.rating ? 'active' : '' %>"></i>
                  <% } %>
                </div>
                <span class="admin-help"><%= new Date(survey.createdAt).toLocaleDateString('pt-BR') %></span>
              </div>
              <% if (survey.comment) { %>
                <p class="survey-list-comment">"<%= survey.comment %>"</p>
              <% } %>
              <div class="admin-help">Página: <%= survey.page || 'Home' %></div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="admin-empty">Nenhum feedback recebido ainda.</div>
      <% } %>
    </article>
  </section>
</div>

<style>
  .admin-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
  }

  .admin-stat-card {
    background: #fff;
    padding: 24px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    border: 1px solid rgba(0,0,0,0.03);
    transition: transform 0.2s;
  }

  .admin-stat-card:hover { transform: translateY(-3px); }

  .admin-stat-icon {
    width: 48px;
    height: 48px;
    background: #f0f7ff;
    color: var(--primary);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
  }

  .admin-stat-info h3 { margin: 0; font-size: 1.5rem; font-weight: 800; color: #0f172a; }
  .admin-stat-info span { font-size: 0.85rem; color: #64748b; font-weight: 500; }

  .chart-panel { background: #fff; padding: 24px; border-radius: 24px; }
  .chart-container { height: 300px; position: relative; margin-top: 20px; }

  .admin-btn-premium {
    background: #0f172a;
    color: #fff;
    border: none;
    padding: 12px 24px;
    border-radius: 12px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.2s;
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.15);
  }

  .admin-btn-premium:hover { transform: translateY(-2px); opacity: 0.9; }

  .survey-list-item { padding: 16px; border: 1px solid #f1f5f9; border-radius: 16px; }
  .survey-list-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .survey-list-stars { color: #e2e8f0; font-size: 0.85rem; }
  .survey-list-stars .active { color: #f59e0b; }
  .survey-list-comment { margin: 0; font-style: italic; color: #334155; font-size: 0.9rem; line-height: 1.5; }

  @media print {
    .no-print, .admin-sidebar, .admin-topbar, .admin-footer, .admin-actions { display: none !important; }
    .admin-main { margin: 0 !important; padding: 0 !important; width: 100% !important; background: #fff !important; }
    .admin-shell { display: block !important; }
    .admin-panel { border: 1px solid #eee !important; break-inside: avoid; }
    body { background: #fff !important; color: #000 !important; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Gráfico de Visitas
    const visitsCtx = document.getElementById('visitsChart').getContext('2d');
    const visitsData = <%- JSON.stringify(dailyVisits) %>;
    
    new Chart(visitsCtx, {
      type: 'line',
      data: {
        labels: visitsData.map(d => {
          const date = new Date(d.day + 'T00:00:00');
          return date.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit' });
        }),
        datasets: [{
          label: 'Acessos únicos',
          data: visitsData.map(d => d.count),
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37, 99, 235, 0.1)',
          fill: true,
          tension: 0.4,
          borderWidth: 3,
          pointRadius: 4,
          pointBackgroundColor: '#fff',
          pointBorderColor: '#2563eb',
          pointBorderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { display: false }
        },
        scales: {
          y: { beginAtZero: true, grid: { color: '#f1f5f9' }, ticks: { stepSize: 1 } },
          x: { grid: { display: false } }
        }
      }
    });

    // Gráfico de Satisfação
    const surveyCtx = document.getElementById('surveyChart').getContext('2d');
    const surveyData = <%- JSON.stringify(surveyChartData) %>;

    new Chart(surveyCtx, {
      type: 'doughnut',
      data: {
        labels: surveyData.labels,
        datasets: [{
          data: surveyData.data,
          backgroundColor: [
            '#ef4444', // 1 estrela - vermelho
            '#f97316', // 2 estrelas - laranja
            '#f59e0b', // 3 estrelas - amarelo/âmbar
            '#84cc16', // 4 estrelas - verde-lima
            '#10b981'  // 5 estrelas - verde esmeralda
          ],
          borderWidth: 0,
          hoverOffset: 15
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: {
              usePointStyle: true,
              padding: 20,
              font: { size: 12, weight: '600' }
            }
          }
        },
        cutout: '70%'
      }
    });
  });
</script>


