<div class="admin-page">
  <section class="admin-form-wrap">
    <div class="admin-section-head">
      <div>
        <h2>Configurações globais</h2>
        <p>Ajuste identidade visual, menu, banner principal, propagandas e cobrança comercial em uma única tela.</p>
      </div>
    </div>

    <form action="/admin/configuracoes" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="admin-structured-block">
        <div class="admin-section-head">
          <div>
            <h2>Marca do site</h2>
            <p>Controle o nome exibido e os textos institucionais sem alterar código.</p>
          </div>
        </div>

        <div class="admin-form-grid">
          <div class="admin-form-row">
            <label for="brandKicker">Linha da marca</label>
            <input type="text" id="brandKicker" name="brandKicker" value="<%= s && s.brandKicker ? s.brandKicker : 'Carreira e cursos' %>">
          </div>
          <div class="admin-form-row">
            <label for="brandName">Nome da marca</label>
            <input type="text" id="brandName" name="brandName" value="<%= s && s.brandName ? s.brandName : 'Agência de Emprego' %>">
          </div>
        </div>

        <div class="admin-form-row">
          <label for="footerDescription">Descrição do rodapé</label>
          <textarea id="footerDescription" name="footerDescription"><%= s && s.footerDescription ? s.footerDescription : 'Agência de Emprego conecta vagas, cursos e orientação profissional em uma experiência mais clara e confiável.' %></textarea>
        </div>
      </div>

      <div class="admin-structured-block">
        <div class="admin-section-head">
          <div>
            <h2>Cores do site</h2>
            <p>Escolha a paleta exata do jeito que quiser. Os campos abaixo substituem o tema padrão.</p>
          </div>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row">
            <label for="themeColor">Tema base</label>
            <select id="themeColor" name="themeColor">
              <option value="white" <%= (!s || s.themeColor === 'white') ? 'selected' : '' %>>Branco</option>
              <option value="black" <%= (s && s.themeColor === 'black') ? 'selected' : '' %>>Preto</option>
              <option value="blue" <%= (s && s.themeColor === 'blue') ? 'selected' : '' %>>Azul</option>
              <option value="pink" <%= (s && s.themeColor === 'pink') ? 'selected' : '' %>>Rosa</option>
            </select>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="primaryColorText">Cor primaria</label>
            <div class="admin-color-field-control">
              <input type="color" id="primaryColorPicker" value="<%= s && s.primaryColor ? s.primaryColor : '#2563eb' %>" data-color-input="primaryColorText">
              <input type="text" id="primaryColorText" name="primaryColor" value="<%= s && s.primaryColor ? s.primaryColor : '#2563eb' %>" placeholder="#2563eb" data-color-text>
            </div>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="accentColorText">Cor de destaque</label>
            <div class="admin-color-field-control">
              <input type="color" id="accentColorPicker" value="<%= s && s.accentColor ? s.accentColor : '#f97316' %>" data-color-input="accentColorText">
              <input type="text" id="accentColorText" name="accentColor" value="<%= s && s.accentColor ? s.accentColor : '#f97316' %>" placeholder="#f97316" data-color-text>
            </div>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="surfaceColorText">Cor dos cartoes</label>
            <div class="admin-color-field-control">
              <input type="color" id="surfaceColorPicker" value="<%= s && s.surfaceColor ? s.surfaceColor : '#ffffff' %>" data-color-input="surfaceColorText">
              <input type="text" id="surfaceColorText" name="surfaceColor" value="<%= s && s.surfaceColor ? s.surfaceColor : '#ffffff' %>" placeholder="#ffffff" data-color-text>
            </div>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="backgroundBaseColorText">Cor de fundo</label>
            <div class="admin-color-field-control">
              <input type="color" id="backgroundBaseColorPicker" value="<%= s && s.backgroundBaseColor ? s.backgroundBaseColor : '#f8fafc' %>" data-color-input="backgroundBaseColorText">
              <input type="text" id="backgroundBaseColorText" name="backgroundBaseColor" value="<%= s && s.backgroundBaseColor ? s.backgroundBaseColor : '#f8fafc' %>" placeholder="#f8fafc" data-color-text>
            </div>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="textColorText">Cor do texto</label>
            <div class="admin-color-field-control">
              <input type="color" id="textColorPicker" value="<%= s && s.textColor ? s.textColor : '#0f172a' %>" data-color-input="textColorText">
              <input type="text" id="textColorText" name="textColor" value="<%= s && s.textColor ? s.textColor : '#0f172a' %>" placeholder="#0f172a" data-color-text>
            </div>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="mutedColorText">Cor do texto secundario</label>
            <div class="admin-color-field-control">
              <input type="color" id="mutedColorPicker" value="<%= s && s.mutedColor ? s.mutedColor : '#475569' %>" data-color-input="mutedColorText">
              <input type="text" id="mutedColorText" name="mutedColor" value="<%= s && s.mutedColor ? s.mutedColor : '#475569' %>" placeholder="#475569" data-color-text>
            </div>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="headingColorText">Cor dos títulos</label>
            <div class="admin-color-field-control">
              <input type="color" id="headingColorPicker" value="<%= s && s.headingColor ? s.headingColor : '#020617' %>" data-color-input="headingColorText">
              <input type="text" id="headingColorText" name="headingColor" value="<%= s && s.headingColor ? s.headingColor : '#020617' %>" placeholder="#020617" data-color-text>
            </div>
          </div>
        </div>
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="backgroundImage">Imagem de fundo</label>
          <input type="file" id="backgroundImage" name="backgroundImage" accept="image/*">
        </div>
        <div class="admin-form-row">
          <label for="cardImageHeight">Altura das imagens do site</label>
          <input type="number" id="cardImageHeight" name="cardImageHeight" min="100" max="500" value="<%= s && s.cardImageHeight ? s.cardImageHeight : 220 %>">
        </div>
      </div>

      <% if (s && s.backgroundImage) { %>
        <div class="admin-image-preview"><img src="/uploads/<%= s.backgroundImage %>" alt="Fundo atual"></div>
      <% } %>

      <div class="admin-form-row">
        <label for="backgroundOpacity">Opacidade do overlay <span class="admin-range-value" id="opacityValue"><%= s && s.backgroundOpacity !== undefined ? s.backgroundOpacity : 1 %></span></label>
        <input type="range" id="backgroundOpacity" name="backgroundOpacity" min="0" max="1" step="0.1" value="<%= s && s.backgroundOpacity !== undefined ? s.backgroundOpacity : 1 %>" oninput="document.getElementById('opacityValue').innerText = this.value">
      </div>

      <div class="admin-structured-block">
        <div class="admin-section-head">
          <div>
            <h2>Menu do site</h2>
            <p>Mantenha todos os itens ajustáveis na mesma reta e visualize o resultado em tempo real antes de salvar.</p>
          </div>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row">
            <label for="navbarPosition">Posição do menu</label>
            <select id="navbarPosition" name="navbarPosition">
              <option value="top" <%= (s && s.navbarPosition === 'top') ? 'selected' : '' %>>Topo</option>
              <option value="left" <%= (s && s.navbarPosition === 'left') ? 'selected' : '' %>>Lateral esquerda</option>
              <option value="right" <%= (s && s.navbarPosition === 'right') ? 'selected' : '' %>>Lateral direita</option>
            </select>
          </div>
          <div class="admin-form-row">
            <label for="navbarAlignment">Alinhamento no topo</label>
            <select id="navbarAlignment" name="navbarAlignment" data-menu-preview-control="alignment">
              <option value="start" <%= (s && s.navbarAlignment === 'start') ? 'selected' : '' %>>Esquerda</option>
              <option value="center" <%= (s && s.navbarAlignment === 'center') ? 'selected' : '' %>>Centro</option>
              <option value="end" <%= (!s || s.navbarAlignment === 'end') ? 'selected' : '' %>>Direita</option>
            </select>
          </div>
          <div class="admin-form-row">
            <label for="navbarWrap">Quebra de linha</label>
            <select id="navbarWrap" name="navbarWrap" data-menu-preview-control="wrap">
              <option value="nowrap" <%= (!s || !s.navbarWrap || s.navbarWrap === 'nowrap') ? 'selected' : '' %>>Sempre na mesma reta</option>
              <option value="wrap" <%= (s && s.navbarWrap === 'wrap') ? 'selected' : '' %>>Permitir quebra</option>
            </select>
          </div>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row">
            <label for="navbarFontSize">Tamanho da fonte</label>
            <input type="number" id="navbarFontSize" name="navbarFontSize" min="12" max="24" value="<%= s && s.navbarFontSize ? s.navbarFontSize : 15 %>" data-menu-preview-control="fontSize">
          </div>
          <div class="admin-form-row">
            <label for="navbarItemGap">Espaçamento entre itens</label>
            <input type="number" id="navbarItemGap" name="navbarItemGap" min="4" max="36" value="<%= s && s.navbarItemGap ? s.navbarItemGap : 10 %>" data-menu-preview-control="gap">
          </div>
          <div class="admin-form-row">
            <label for="navbarItemPaddingX">Padding lateral</label>
            <input type="number" id="navbarItemPaddingX" name="navbarItemPaddingX" min="8" max="32" value="<%= s && s.navbarItemPaddingX ? s.navbarItemPaddingX : 16 %>" data-menu-preview-control="paddingX">
          </div>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row">
            <label for="navbarItemMinHeight">Altura do item</label>
            <input type="number" id="navbarItemMinHeight" name="navbarItemMinHeight" min="36" max="64" value="<%= s && s.navbarItemMinHeight ? s.navbarItemMinHeight : 44 %>" data-menu-preview-control="minHeight">
          </div>
        </div>

        <div class="admin-live-preview" data-menu-preview>
          <div class="admin-live-preview-head">
            <strong>Prévia do menu</strong>
            <span>O preview responde na hora. Para publicar no site, clique em salvar configurações.</span>
          </div>
          <div class="admin-menu-preview-shell">
            <div class="admin-menu-preview-brand">
              <span class="admin-menu-preview-mark"><i class="fas fa-briefcase"></i></span>
              <div>
                <small><%= s && s.brandKicker ? s.brandKicker : 'Carreira e cursos' %></small>
                <strong><%= s && s.brandName ? s.brandName : 'Agência de Emprego' %></strong>
              </div>
            </div>
            <nav class="admin-menu-preview-links" data-menu-preview-links>
              <% const previewMenus = typeof menuPreviewItems !== 'undefined' && menuPreviewItems.length > 0 ? menuPreviewItems : [{ label: 'Início' }, { label: 'Vagas' }, { label: 'Cursos' }, { label: 'Seleções públicas' }, { label: 'Sobre' }, { label: 'Contato' }]; %>
              <% previewMenus.forEach((item, index) => { %>
                <span class="admin-menu-preview-link <%= index === 0 ? 'is-active' : '' %>"><%= item.label %></span>
              <% }) %>
            </nav>
          </div>
        </div>
      </div>

      <div class="admin-structured-block">
        <div class="admin-section-head">
          <div>
            <h2>Banner principal da home</h2>
            <p>Controle o conteúdo, o tamanho, o alinhamento e a posição do bloco principal.</p>
          </div>
        </div>

        <div class="admin-form-row">
          <label for="heroKicker">Linha superior do banner</label>
          <input type="text" id="heroKicker" name="heroKicker" value="<%= s && s.heroKicker ? s.heroKicker : 'Plataforma profissional para carreira' %>">
        </div>
        <div class="admin-form-row">
          <label for="heroTitle">Título do banner</label>
          <input type="text" id="heroTitle" name="heroTitle" value="<%= s && s.heroTitle ? s.heroTitle : 'Conecte talento, contratação e qualificação em uma vitrine que transmite confiança.' %>">
        </div>
        <div class="admin-form-row">
          <label for="heroDescription">Descrição do banner</label>
          <textarea id="heroDescription" name="heroDescription"><%= s && s.heroDescription ? s.heroDescription : 'Sua agência agora apresenta vagas e cursos em uma experiência mais forte comercialmente: clara para quem busca oportunidade e convincente para quem quer divulgar serviços e atrair candidatos qualificados.' %></textarea>
        </div>

        <div class="admin-structured-block">
          <div class="admin-section-head">
            <div>
              <h2>Botões do banner</h2>
              <p>Edite os quatro botões exibidos ao lado do texto principal do painel inicial.</p>
            </div>
          </div>

          <div class="admin-form-grid admin-form-grid-3">
            <div class="admin-form-row"><label for="heroActionPrimaryLabel">Botão 1</label><input type="text" id="heroActionPrimaryLabel" name="heroActionPrimaryLabel" value="<%= s && s.heroActionPrimaryLabel ? s.heroActionPrimaryLabel : 'Cadastrar currículo' %>"></div>
            <div class="admin-form-row"><label for="heroActionPrimaryLink">Link do botão 1</label><input type="text" id="heroActionPrimaryLink" name="heroActionPrimaryLink" value="<%= s && s.heroActionPrimaryLink ? s.heroActionPrimaryLink : '/acesso-candidato?section=register-candidate' %>"></div>
          </div>
          <div class="admin-form-grid admin-form-grid-3">
            <div class="admin-form-row"><label for="heroActionSecondaryLabel">Botão 2</label><input type="text" id="heroActionSecondaryLabel" name="heroActionSecondaryLabel" value="<%= s && s.heroActionSecondaryLabel ? s.heroActionSecondaryLabel : 'Explorar vagas' %>"></div>
            <div class="admin-form-row"><label for="heroActionSecondaryLink">Link do botão 2</label><input type="text" id="heroActionSecondaryLink" name="heroActionSecondaryLink" value="<%= s && s.heroActionSecondaryLink ? s.heroActionSecondaryLink : '/vagas' %>"></div>
          </div>
          <div class="admin-form-grid admin-form-grid-3">
            <div class="admin-form-row"><label for="heroActionTertiaryLabel">Botão 3</label><input type="text" id="heroActionTertiaryLabel" name="heroActionTertiaryLabel" value="<%= s && s.heroActionTertiaryLabel ? s.heroActionTertiaryLabel : 'Conhecer cursos' %>"></div>
            <div class="admin-form-row"><label for="heroActionTertiaryLink">Link do botão 3</label><input type="text" id="heroActionTertiaryLink" name="heroActionTertiaryLink" value="<%= s && s.heroActionTertiaryLink ? s.heroActionTertiaryLink : '/cursos' %>"></div>
          </div>
          <div class="admin-form-grid admin-form-grid-3">
            <div class="admin-form-row"><label for="heroActionQuaternaryLabel">Botão 4</label><input type="text" id="heroActionQuaternaryLabel" name="heroActionQuaternaryLabel" value="<%= s && s.heroActionQuaternaryLabel ? s.heroActionQuaternaryLabel : 'Falar com a equipe' %>"></div>
            <div class="admin-form-row"><label for="heroActionQuaternaryLink">Link do botão 4</label><input type="text" id="heroActionQuaternaryLink" name="heroActionQuaternaryLink" value="<%= s && s.heroActionQuaternaryLink ? s.heroActionQuaternaryLink : '/contato' %>"></div>
          </div>
        </div>

        <div class="admin-structured-block">
          <div class="admin-section-head">
            <div>
              <h2>Indicadores do banner</h2>
              <p>Edite os textos e, se quiser, informe números fixos. Se deixar vazio, o sistema usa a quantidade real cadastrada.</p>
            </div>
          </div>

          <div class="admin-form-grid admin-form-grid-3">
            <div class="admin-form-row"><label for="heroStat1Value">Número 1</label><input type="text" id="heroStat1Value" name="heroStat1Value" value="<%= s && s.heroStat1Value ? s.heroStat1Value : '' %>" placeholder="Ex.: 1"></div>
            <div class="admin-form-row"><label for="heroStat1Label">Texto 1</label><input type="text" id="heroStat1Label" name="heroStat1Label" value="<%= s && s.heroStat1Label ? s.heroStat1Label : 'vagas com apresentação mais objetiva' %>"></div>
          </div>
          <div class="admin-form-grid admin-form-grid-3">
            <div class="admin-form-row"><label for="heroStat2Value">Número 2</label><input type="text" id="heroStat2Value" name="heroStat2Value" value="<%= s && s.heroStat2Value ? s.heroStat2Value : '' %>" placeholder="Ex.: 2"></div>
            <div class="admin-form-row"><label for="heroStat2Label">Texto 2</label><input type="text" id="heroStat2Label" name="heroStat2Label" value="<%= s && s.heroStat2Label ? s.heroStat2Label : 'cursos posicionados para conversão' %>"></div>
          </div>
          <div class="admin-form-grid admin-form-grid-3">
            <div class="admin-form-row"><label for="heroStat3Value">Número 3</label><input type="text" id="heroStat3Value" name="heroStat3Value" value="<%= s && s.heroStat3Value ? s.heroStat3Value : '' %>" placeholder="Ex.: 1"></div>
            <div class="admin-form-row"><label for="heroStat3Label">Texto 3</label><input type="text" id="heroStat3Label" name="heroStat3Label" value="<%= s && s.heroStat3Label ? s.heroStat3Label : 'editais públicos com cronograma e quadro de vagas' %>"></div>
          </div>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row">
            <label for="heroPlacement">Posição do painel inicial na home</label>
            <select id="heroPlacement" name="heroPlacement">
              <option value="before_top_ads" <%= (s && s.heroPlacement === 'before_top_ads') ? 'selected' : '' %>>Antes das propagandas superiores</option>
              <option value="after_top_ads" <%= (!s || !s.heroPlacement || s.heroPlacement === 'after_top_ads') ? 'selected' : '' %>>Entre propagandas superiores e mural</option>
              <option value="after_mural" <%= (s && s.heroPlacement === 'after_mural') ? 'selected' : '' %>>Depois do mural publicitário</option>
            </select>
          </div>
          <div class="admin-form-row"><label for="heroHeight">Altura mínima do banner</label><input type="number" id="heroHeight" name="heroHeight" min="0" max="900" value="<%= s && s.heroHeight !== undefined ? s.heroHeight : 0 %>"></div>
          <div class="admin-form-row"><label for="heroPadding">Espa?amento interno</label><input type="number" id="heroPadding" name="heroPadding" min="20" max="120" value="<%= s && s.heroPadding ? s.heroPadding : 42 %>"></div>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row"><label for="heroTitleSize">Tamanho máximo do título</label><input type="number" id="heroTitleSize" name="heroTitleSize" min="36" max="120" value="<%= s && s.heroTitleSize ? s.heroTitleSize : 72 %>"></div>
          <div class="admin-form-row"><label for="heroContentWidth">Largura máxima do quadro de informações</label><input type="number" id="heroContentWidth" name="heroContentWidth" min="320" max="1100" value="<%= s && s.heroContentWidth ? s.heroContentWidth : 720 %>"></div>
          <div class="admin-form-row"><label for="heroKickerSize">Tamanho da linha superior</label><input type="number" id="heroKickerSize" name="heroKickerSize" min="10" max="28" value="<%= s && s.heroKickerSize ? s.heroKickerSize : 12 %>"></div>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row"><label for="heroDescriptionSize">Tamanho do texto descritivo</label><input type="number" id="heroDescriptionSize" name="heroDescriptionSize" min="13" max="28" value="<%= s && s.heroDescriptionSize ? s.heroDescriptionSize : 17 %>"></div>
        </div>

        <div class="admin-form-row">
          <small class="admin-form-help">Escolha em que ponto da home o painel inicial sera exibido. Isso permite reorganizar a entrada principal do site sem alterar codigo.</small>
        </div>
        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row admin-form-checkbox admin-form-checkbox-card"><label><input type="checkbox" name="heroEnabled" <%= (!s || s.heroEnabled !== false) ? 'checked' : '' %>><span>Exibir painel inicial</span></label></div>
          <div class="admin-form-row admin-form-checkbox admin-form-checkbox-card"><label><input type="checkbox" name="heroShowKicker" <%= (!s || s.heroShowKicker !== false) ? 'checked' : '' %>><span>Mostrar linha superior</span></label></div>
          <div class="admin-form-row admin-form-checkbox admin-form-checkbox-card"><label><input type="checkbox" name="heroShowDescription" <%= (!s || s.heroShowDescription !== false) ? 'checked' : '' %>><span>Mostrar descrição</span></label></div>
          <div class="admin-form-row admin-form-checkbox admin-form-checkbox-card"><label><input type="checkbox" name="heroShowActions" <%= (!s || s.heroShowActions !== false) ? 'checked' : '' %>><span>Mostrar bot?es</span></label></div>
          <div class="admin-form-row admin-form-checkbox admin-form-checkbox-card"><label><input type="checkbox" name="heroShowStats" <%= (!s || s.heroShowStats !== false) ? 'checked' : '' %>><span>Mostrar indicadores</span></label></div>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row"><label for="heroMaxWidth">Largura máxima do painel</label><input type="number" id="heroMaxWidth" name="heroMaxWidth" min="0" max="1600" value="<%= s && s.heroMaxWidth ? s.heroMaxWidth : 0 %>"></div>
          <div class="admin-form-row"><label for="heroBorderRadius">Arredondamento do painel</label><input type="number" id="heroBorderRadius" name="heroBorderRadius" min="0" max="80" value="<%= s && s.heroBorderRadius ? s.heroBorderRadius : 28 %>"></div>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row admin-color-field">
            <label for="heroBackgroundColorText">Cor de fundo do painel</label>
            <div class="admin-color-field-control">
              <input type="color" id="heroBackgroundColorPicker" value="<%= s && s.heroBackgroundColor && /^#([0-9a-fA-F]{6})$/.test(s.heroBackgroundColor) ? s.heroBackgroundColor : '#0f172a' %>" data-color-input="heroBackgroundColorText">
              <input type="text" id="heroBackgroundColorText" name="heroBackgroundColor" value="<%= s && s.heroBackgroundColor ? s.heroBackgroundColor : '' %>" placeholder="#0f172a ou linear-gradient(...)" data-color-text>
            </div>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="heroContentBackgroundColorText">Cor do quadro interno</label>
            <div class="admin-color-field-control">
              <input type="color" id="heroContentBackgroundColorPicker" value="<%= s && s.heroContentBackgroundColor && /^#([0-9a-fA-F]{6})$/.test(s.heroContentBackgroundColor) ? s.heroContentBackgroundColor : '#ffffff' %>" data-color-input="heroContentBackgroundColorText">
              <input type="text" id="heroContentBackgroundColorText" name="heroContentBackgroundColor" value="<%= s && s.heroContentBackgroundColor ? s.heroContentBackgroundColor : '' %>" placeholder="rgba(255,255,255,0.08)" data-color-text>
            </div>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="heroTextColorText">Cor principal do texto</label>
            <div class="admin-color-field-control">
              <input type="color" id="heroTextColorPicker" value="<%= s && s.heroTextColor ? s.heroTextColor : '#ffffff' %>" data-color-input="heroTextColorText">
              <input type="text" id="heroTextColorText" name="heroTextColor" value="<%= s && s.heroTextColor ? s.heroTextColor : '#ffffff' %>" placeholder="#ffffff" data-color-text>
            </div>
          </div>
          <div class="admin-form-row admin-color-field">
            <label for="heroMutedTextColorText">Cor do texto secundario</label>
            <div class="admin-color-field-control">
              <input type="color" id="heroMutedTextColorPicker" value="<%= s && s.heroMutedTextColor && /^#([0-9a-fA-F]{6})$/.test(s.heroMutedTextColor) ? s.heroMutedTextColor : '#cbd5e1' %>" data-color-input="heroMutedTextColorText">
              <input type="text" id="heroMutedTextColorText" name="heroMutedTextColor" value="<%= s && s.heroMutedTextColor ? s.heroMutedTextColor : '' %>" placeholder="rgba(255,255,255,0.82)" data-color-text>
            </div>
          </div>
        </div>


        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row">
