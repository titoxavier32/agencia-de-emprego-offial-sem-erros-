<script>
  const previewSizePreset = document.getElementById('previewSizePreset');
  const previewDialogMaxWidth = document.getElementById('previewDialogMaxWidth');
  const previewDialogMinHeight = document.getElementById('previewDialogMinHeight');
  const previewInfoPanelWidth = document.getElementById('previewInfoPanelWidth');

  const presets = {
    small: { maxW: 900, minH: 68, infoW: 300 },
    medium: { maxW: 1140, minH: 76, infoW: 340 },
    large: { maxW: 1380, minH: 82, infoW: 380 }
  };

  previewSizePreset.addEventListener('change', () => {
    const val = previewSizePreset.value;
    if (presets[val]) {
      previewDialogMaxWidth.value = presets[val].maxW;
      previewDialogMinHeight.value = presets[val].minH;
      previewInfoPanelWidth.value = presets[val].infoW;
    }
  });

  // Se o usuário clicar manualmente nos campos numéricos, mudamos o preset para 'custom'
  [previewDialogMaxWidth, previewDialogMinHeight, previewInfoPanelWidth].forEach(el => {
    el.addEventListener('input', () => {
      previewSizePreset.value = 'custom';
    });
  });
</script>
