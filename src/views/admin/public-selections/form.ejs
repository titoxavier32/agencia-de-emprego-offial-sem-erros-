<div class="admin-page">
  <section class="admin-form-wrap">
    <div class="admin-section-head">
      <div>
        <h2><%= title %></h2>
        <p>Cadastre concursos e processos seletivos e, se quiser, coloque esse item para rodar no banner principal da home.</p>
      </div>
      <a href="/admin/selecoes-publicas" class="admin-btn-ghost">Voltar</a>
    </div>

    <% if (typeof formError !== 'undefined' && formError) { %>
      <div class="admin-alert"><%= formError %></div>
    <% } %>

    <form action="<%= publicSelection ? '/admin/selecoes-publicas/editar/' + publicSelection.id : '/admin/selecoes-publicas/nova' %>" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="category">Categoria</label>
          <select id="category" name="category">
            <option value="processo_seletivo" <%= !publicSelection || publicSelection.category === 'processo_seletivo' ? 'selected' : '' %>>Processo seletivo</option>
            <option value="concurso_publico" <%= publicSelection && publicSelection.category === 'concurso_publico' ? 'selected' : '' %>>Concurso publico</option>
          </select>
        </div>
        <div class="admin-form-row">
          <label for="sphere">Esfera</label>
          <select id="sphere" name="sphere">
            <option value="Federal" <%= publicSelection && publicSelection.sphere === 'Federal' ? 'selected' : '' %>>Federal</option>
            <option value="Estadual" <%= publicSelection && publicSelection.sphere === 'Estadual' ? 'selected' : '' %>>Estadual</option>
            <option value="Municipal" <%= !publicSelection || publicSelection.sphere === 'Municipal' ? 'selected' : '' %>>Municipal</option>
            <option value="Processo Seletivo" <%= publicSelection && publicSelection.sphere === 'Processo Seletivo' ? 'selected' : '' %>>Processo Seletivo</option>
          </select>
        </div>
        <div class="admin-form-row">
          <label for="region">Regiao</label>
          <select id="region" name="region">
            <option value="Brasil" <%= publicSelection && publicSelection.region === 'Brasil' ? 'selected' : '' %>>Brasil</option>
            <option value="Rondonia" <%= !publicSelection || publicSelection.region === 'Rondonia' ? 'selected' : '' %>>Rondonia</option>
          </select>
        </div>
      </div>

      <div class="admin-form-row">
        <label for="title">Titulo</label>
        <input type="text" id="title" name="title" value="<%= publicSelection ? publicSelection.title : '' %>" required placeholder="Ex: Concurso Prefeitura 2026">
      </div>

      <div class="admin-form-row">
        <label for="description">Resumo</label>
        <textarea id="description" name="description" rows="4"><%= publicSelection ? publicSelection.description : '' %></textarea>
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="salary">Salario / Remuneracao</label>
          <input type="text" id="salary" name="salary" value="<%= publicSelection ? publicSelection.salary : '' %>" placeholder="Ex: ate R$ 4.500,00">
        </div>
        <div class="admin-form-row">
          <label for="educationLevel">Escolaridade</label>
          <input type="text" id="educationLevel" name="educationLevel" value="<%= publicSelection ? publicSelection.educationLevel : '' %>" placeholder="Ex: Medio e Superior">
        </div>
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="registrationStartDate">Inicio das inscricoes</label>
          <input type="date" id="registrationStartDate" name="registrationStartDate" value="<%= publicSelection && publicSelection.registrationStartDate ? publicSelection.registrationStartDate : '' %>">
        </div>
        <div class="admin-form-row">
          <label for="registrationEndDate">Fim das inscricoes</label>
          <input type="date" id="registrationEndDate" name="registrationEndDate" value="<%= publicSelection && publicSelection.registrationEndDate ? publicSelection.registrationEndDate : '' %>">
        </div>
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="link">Link do edital</label>
          <input type="url" id="link" name="link" value="<%= publicSelection ? publicSelection.link : '' %>" placeholder="https://site.com/edital.pdf">
        </div>
        <div class="admin-form-row">
          <label for="processWebsite">Site do processo</label>
          <input type="url" id="processWebsite" name="processWebsite" value="<%= publicSelection ? publicSelection.processWebsite : '' %>" placeholder="https://site-da-banca.com">
        </div>
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="image">Imagem de capa <% if (publicSelection && publicSelection.image) { %><span class="admin-form-help">(atual mantida)</span><% } %></label>
          <input type="file" id="image" name="image" accept="image/*" <%= publicSelection ? '' : 'required' %>>
        </div>
        <div class="admin-form-row">
          <label for="noticePdf">PDF do edital <% if (publicSelection && publicSelection.noticePdf) { %><span class="admin-form-help">(atual mantido)</span><% } %></label>
          <input type="file" id="noticePdf" name="noticePdf" accept="application/pdf,.pdf">
        </div>
      </div>

      <div class="admin-form-row">
        <label for="status">Status</label>
        <input type="text" id="status" name="status" value="<%= publicSelection ? publicSelection.status : '' %>" placeholder="Ex: Publicado">
      </div>

      <div class="admin-structured-block">
        <div class="admin-section-head">
          <div>
            <h2>Banner principal da home</h2>
            <p>Ative para exibir este concurso ou processo seletivo no banner rotativo da pagina inicial.</p>
          </div>
        </div>

        <div class="admin-form-grid">
          <div class="admin-form-row admin-form-checkbox admin-form-checkbox-card">
            <label>
              <input type="checkbox" name="showInHero" <%= publicSelection && publicSelection.showInHero ? 'checked' : '' %>>
              <span>Exibir no banner principal</span>
            </label>
          </div>
          <div class="admin-form-row">
            <label for="heroOrder">Ordem do slide</label>
            <input type="number" id="heroOrder" name="heroOrder" min="0" max="99" value="<%= publicSelection && publicSelection.heroOrder !== undefined ? publicSelection.heroOrder : 0 %>">
          </div>
        </div>

        <div class="admin-form-row">
          <label for="heroKicker">Linha superior do slide</label>
          <input type="text" id="heroKicker" name="heroKicker" value="<%= publicSelection && publicSelection.heroKicker ? publicSelection.heroKicker : '' %>" placeholder="Ex: Concurso em destaque">
        </div>

        <div class="admin-form-row">
          <label for="heroSummary">Resumo curto para o banner</label>
          <textarea id="heroSummary" name="heroSummary" rows="3" placeholder="Resumo curto e direto para aparecer no banner."><%= publicSelection && publicSelection.heroSummary ? publicSelection.heroSummary : '' %></textarea>
        </div>

        <div class="admin-form-row">
          <label for="heroButtonLabel">Texto do botao</label>
          <input type="text" id="heroButtonLabel" name="heroButtonLabel" value="<%= publicSelection && publicSelection.heroButtonLabel ? publicSelection.heroButtonLabel : '' %>" placeholder="Ex: Ver edital">
        </div>
      </div>

      <% if (publicSelection && publicSelection.image) { %>
        <div class="admin-image-preview">
          <img src="/uploads/<%= publicSelection.image %>" alt="Imagem atual">
        </div>
      <% } %>

      <div class="admin-actions">
        <button type="submit" class="admin-btn">Salvar divulgacao</button>
      </div>
    </form>
  </section>
</div>
