<div class="admin-page">
  <section class="admin-form-wrap">
    <div class="admin-section-head">
      <div>
        <h2><%= title %></h2>
        <p>O banner agora nasce a partir do mapa visual. Aqui voce cuida do conteudo, do tamanho e do comportamento.</p>
      </div>
      <a href="/admin/propagandas" class="admin-btn-ghost">Voltar ao mapa visual</a>
    </div>

    <% if (typeof formError !== 'undefined' && formError) { %>
      <div class="admin-alert"><%= formError %></div>
    <% } %>

    <%
      const placementLabel = advertisement && advertisement.placement === 'hero_top'
        ? 'Acima da plataforma profissional'
        : (advertisement && advertisement.placement === 'hero_slider' ? 'Carrossel do Hero (Principal)' : 'Mural publicitario da home');
    %>

    <form action="<%= advertisement && advertisement.id ? '/admin/propagandas/editar/' + advertisement.id : '/admin/propagandas/nova' %>" method="POST" enctype="multipart/form-data" class="admin-form">
      <input type="hidden" name="placement" value="<%= advertisement ? advertisement.placement : 'mural_home' %>">
      <input type="hidden" name="groupName" value="<%= advertisement ? (advertisement.groupName || 'Geral') : 'Geral' %>">
      <input type="hidden" name="position" value="<%= advertisement ? (advertisement.position || 1) : 1 %>">

      <div class="admin-structured-block">
        <div class="admin-section-head">
          <div>
            <h2>Posicionamento visual</h2>
            <p>Para trocar o local do banner, use o mapa visual da pagina de propagandas e arraste ou clique no slot desejado.</p>
          </div>
          <a href="/admin/propagandas" class="admin-btn-secondary">Abrir mapa visual</a>
        </div>

        <div class="admin-form-grid admin-form-grid-3">
          <div class="admin-form-row">
            <label>Area escolhida</label>
            <input type="text" value="<%= placementLabel %>" readonly>
          </div>
          <div class="admin-form-row">
            <label>Grupo visual</label>
            <input type="text" value="<%= advertisement ? (advertisement.groupName || 'Geral') : 'Geral' %>" readonly>
          </div>
          <div class="admin-form-row">
            <label>Posicao visual</label>
            <input type="text" value="<%= advertisement ? (advertisement.position || 1) : 1 %>" readonly>
          </div>
        </div>
      </div>

      <div class="admin-form-row">
        <label for="image">Imagem animada ou estatica <span class="admin-help"><%= advertisement && advertisement.id ? '(opcional na edicao)' : '(obrigatoria)' %></span></label>
        <input type="file" id="image" name="image" accept="image/png,image/jpeg,image/jpg,image/gif,image/webp" <%= advertisement && advertisement.id ? '' : 'required' %>>
        <div class="admin-help">Aceita PNG, JPEG, JPG, GIF e WEBP com ate 50 MB.</div>
      </div>

      <div class="admin-form-row">
        <label for="title">Titulo interno da propaganda <span class="admin-help">(opcional)</span></label>
        <input type="text" id="title" name="title" value="<%= advertisement ? (advertisement.title || '') : '' %>" placeholder="Use apenas para identificar no painel administrativo">
      </div>

      <div class="admin-form-row">
        <label for="description">Descricao <span class="admin-help">(Sera o resumo no carrossel do Hero)</span></label>
        <textarea id="description" name="description" placeholder="Texto que aparece abaixo do titulo no banner" required><%= advertisement ? (advertisement.description || '') : '' %></textarea>
      </div>

      <% if (advertisement && advertisement.placement === 'hero_slider') { %>
        <div class="admin-form-grid">
          <div class="admin-form-row">
            <label for="heroKicker">Kicker / Chapeu <span class="admin-help">(Texto pequeno acima do titulo)</span></label>
            <input type="text" id="heroKicker" name="heroKicker" value="<%= advertisement.heroKicker || '' %>" placeholder="Ex: NOVIDADE, DESTAQUE...">
          </div>
          <div class="admin-form-row">
            <label for="heroButtonLabel">Texto do Botao</label>
            <input type="text" id="heroButtonLabel" name="heroButtonLabel" value="<%= advertisement.heroButtonLabel || 'Saiba mais' %>">
          </div>
        </div>
      <% } %>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="link">Link ao clicar <span class="admin-help">(opcional)</span></label>
          <input type="url" id="link" name="link" value="<%= advertisement ? (advertisement.link || '') : '' %>" placeholder="https://seusite.com">
        </div>

        <div class="admin-form-row">
          <label for="animation">Animacao <span class="admin-help">(opcional)</span></label>
          <select id="animation" name="animation">
            <option value="pulse" <%= !advertisement || advertisement.animation === 'pulse' ? 'selected' : '' %>>Pulse</option>
            <option value="float" <%= advertisement && advertisement.animation === 'float' ? 'selected' : '' %>>Float</option>
            <option value="glow" <%= advertisement && advertisement.animation === 'glow' ? 'selected' : '' %>>Glow</option>
            <option value="zoom" <%= advertisement && advertisement.animation === 'zoom' ? 'selected' : '' %>>Zoom</option>
            <option value="none" <%= advertisement && advertisement.animation === 'none' ? 'selected' : '' %>>Sem animacao</option>
          </select>
        </div>
      </div>

      <div class="admin-form-grid admin-form-grid-3">
        <div class="admin-form-row">
          <label for="width">Largura em pixels <span class="admin-help">(opcional)</span></label>
          <input type="number" id="width" name="width" min="120" max="1600" value="<%= advertisement ? advertisement.width : 500 %>">
        </div>

        <div class="admin-form-row">
          <label for="height">Altura em pixels <span class="admin-help">(opcional)</span></label>
          <input type="number" id="height" name="height" min="80" max="1200" value="<%= advertisement ? advertisement.height : 105 %>">
        </div>

        <div class="admin-form-row">
          <label for="order">Ordem adicional</label>
          <input type="number" id="order" name="order" min="0" max="999" value="<%= advertisement ? advertisement.order : 0 %>">
        </div>
      </div>

      <div class="admin-form-checkbox">
        <label><input type="checkbox" name="isActive" <%= !advertisement || advertisement.isActive ? 'checked' : '' %>> Exibir no site</label>
      </div>
      <div class="admin-help">Desative esta opcao quando quiser manter a propaganda cadastrada no painel sem mostrar no site.</div>

        <div class="admin-image-preview">
          <img src="/images/propagandas/<%= advertisement.image %>" alt="Imagem atual">
        </div>

      <div class="admin-help">Somente a imagem e obrigatoria. O mapa visual controla area, grupo e posicao principal do banner.</div>

      <div class="admin-actions">
        <button type="submit" class="admin-btn">Salvar propaganda</button>
      </div>
    </form>
  </section>
</div>
