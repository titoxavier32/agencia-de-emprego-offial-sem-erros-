<div class="admin-page">
  <section class="admin-hero">
    <div class="admin-kicker">Mapa visual de banners</div>
    <h1>Posicione as propagandas direto no layout do site.</h1>
    <p>Clique em um slot vazio para cadastrar um banner naquele ponto. Arraste um banner existente para outro slot para trocar o posicionamento sem depender de seletor no formulario.</p>
  </section>

  <section class="admin-form-wrap">
    <div class="admin-section-head">
      <div>
        <h2>Mapa visual das areas publicitarias</h2>
        <p>As linhas representam os grupos e cada slot representa a posicao do banner dentro da area selecionada.</p>
      </div>
      <a href="/admin/propagandas/nova" class="admin-btn"><i class="fas fa-plus"></i><span>Nova propaganda</span></a>
    </div>

    <div class="admin-ad-layout-board">
      <% visualSections.forEach(section => { %>
        <article class="admin-ad-layout-section">
          <div class="admin-ad-layout-head">
            <div>
              <div class="admin-kicker">
                <%= section.key === 'hero_top' ? 'Topo da home' : (section.key === 'hero_slider' ? 'Banner Principal' : 'Mural da home') %>
              </div>
              <h3><%= section.title %></h3>
              <p><%= section.description %></p>
            </div>
            <button type="button" class="admin-btn-secondary" data-add-group data-placement="<%= section.key %>">
              <i class="fas fa-layer-group"></i>
              <span>Novo grupo visual</span>
            </button>
          </div>

          <div class="admin-ad-layout-preview admin-ad-layout-preview--<%= section.key %>">
            <% section.groups.forEach(group => { %>
              <section class="admin-ad-group-row">
                <div class="admin-ad-group-meta">
                  <strong><%= group.groupName %></strong>
                  <span><%= group.slots.filter(slot => slot.advertisement).length %> banner(s)</span>
                  <a href="/admin/propagandas/nova?placement=<%= encodeURIComponent(section.key) %>&groupName=<%= encodeURIComponent(group.groupName) %>&position=1" class="admin-btn-ghost">Adicionar neste grupo</a>
                </div>

                <div class="admin-ad-slot-grid">
                  <% group.slots.forEach(slot => { %>
                    <div
                      class="admin-ad-slot <%= slot.advertisement ? 'is-filled' : 'is-empty' %>"
                      data-drop-slot
                      data-placement="<%= section.key %>"
                      data-group-name="<%= group.groupName %>"
                      data-position="<%= slot.position %>">
                      <div class="admin-ad-slot-label">Posicao <%= slot.position %></div>

                      <% if (slot.advertisement) { %>
                        <article class="admin-ad-card <%= slot.advertisement.isActive ? '' : 'is-inactive' %>" draggable="true" data-draggable-ad data-ad-id="<%= slot.advertisement.id %>">
                          <div class="admin-ad-card-media">
                            <% if (slot.advertisement.image) { %>
                              <img src="/images/propagandas/<%= slot.advertisement.image %>" alt="Banner" class="admin-thumb" data-lightbox-src="/images/propagandas/<%= slot.advertisement.image %>">
                            <% } else { %>
                              <div class="admin-thumb-fallback"><i class="fas fa-image"></i></div>
                            <% } %>
                          </div>
                          <div class="admin-ad-card-body">
                            <strong><%= slot.advertisement.title || 'Banner sem titulo interno' %></strong>
                            <span><%= slot.advertisement.width %> x <%= slot.advertisement.height %> px</span>
                            <span><%= slot.advertisement.isActive ? 'Visivel no site' : 'Oculto no site' %></span>
                          </div>
                          <div class="admin-ad-card-actions">
                            <a href="/admin/propagandas/editar/<%= slot.advertisement.id %>" class="admin-btn-secondary">Editar</a>
                            <form action="/admin/propagandas/deletar/<%= slot.advertisement.id %>" method="POST" onsubmit="return confirm('Excluir esta propaganda?');">
                              <button type="submit" class="admin-btn-danger">Excluir</button>
                            </form>
                          </div>
                        </article>
                      <% } else { %>
                        <a href="/admin/propagandas/nova?placement=<%= encodeURIComponent(section.key) %>&groupName=<%= encodeURIComponent(group.groupName) %>&position=<%= slot.position %>" class="admin-ad-slot-create">
                          <i class="fas fa-plus"></i>
                          <span>Cadastrar banner aqui</span>
                        </a>
                      <% } %>
                    </div>
                  <% }) %>
                </div>
              </section>
            <% }) %>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <% if (advertisements.length > 0) { %>
    <section class="admin-table-wrap">
      <div class="admin-section-head">
        <div>
          <h2>Resumo tecnico</h2>
          <p>Lista auxiliar para conferir link, grupo, ordem e status de cada banner cadastrado.</p>
        </div>
      </div>

      <table class="admin-table">
        <thead>
          <tr>
            <th>Imagem</th>
            <th>Identificacao</th>
            <th>Area</th>
            <th>Grupo</th>
            <th>Posicao</th>
            <th>Status</th>
            <th>Acoes</th>
          </tr>
        </thead>
        <tbody>
          <% advertisements.forEach(item => { %>
            <tr>
              <td>
                <% if (item.image) { %>
                  <img src="/images/propagandas/<%= item.image %>" alt="Propaganda cadastrada" class="admin-thumb" data-lightbox-src="/images/propagandas/<%= item.image %>">
                <% } else { %>
                  <span class="admin-help">Sem imagem</span>
                <% } %>
              </td>
              <td>
                <strong><%= item.title || 'Propaganda sem titulo interno' %></strong>
                <div class="admin-help"><%= item.link || 'Sem link' %></div>
              </td>
              <td>
                <span class="admin-badge neutral">
                  <%= item.placement === 'hero_top' ? 'Topo da home' : (item.placement === 'hero_slider' ? 'Carrossel Hero' : 'Mural da home') %>
                </span>
              </td>
              <td><span class="admin-badge neutral"><%= item.groupName || 'Geral' %></span></td>
              <td><span class="admin-badge neutral"><%= item.position || 1 %></span></td>
              <td><span class="admin-badge <%= item.isActive ? 'success' : 'warning' %>"><%= item.isActive ? 'Exibida no site' : 'Oculta no site' %></span></td>
              <td>
                <div class="admin-actions">
                  <a href="/admin/propagandas/editar/<%= item.id %>" class="admin-btn-secondary">Editar</a>
                  <form action="/admin/propagandas/deletar/<%= item.id %>" method="POST" onsubmit="return confirm('Excluir esta propaganda?');">
                    <button type="submit" class="admin-btn-danger">Excluir</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  <% } %>
</div>
