<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - <%= typeof title !== 'undefined' ? title : 'Painel de controle' %></title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/css/admin-professional.css">
</head>
<body class="admin-body">
  <% const adminMenuGroups = (typeof adminSidebarGroups !== 'undefined' && Array.isArray(adminSidebarGroups) && adminSidebarGroups.length > 0) ? adminSidebarGroups : []; %>

  <div class="admin-shell">
    <aside class="admin-sidebar">
      <div style="display:flex;flex-direction:column;height:100%;gap:18px;">
        <a href="/admin/dashboard" class="admin-brand">
          <span class="admin-brand-mark"><i class="fas fa-compass-drafting"></i></span>
          <span class="admin-brand-copy">
            <small>Painel administrativo</small>
            <strong>Agencia de Emprego</strong>
          </span>
        </a>

        <nav class="admin-nav">
          <% adminMenuGroups.forEach(group => { %>
            <section class="admin-nav-group">
              <div class="admin-nav-group-title"><%= group.title %></div>
              <div class="admin-nav-group-links">
                <% group.items.forEach(item => { %>
                  <a href="<%= item.href %>" class="admin-nav-link <%= item.active ? 'is-active' : '' %>">
                    <i class="fas <%= item.icon %>"></i>
                    <span><%= item.label %></span>
                  </a>
                <% }) %>
              </div>
            </section>
          <% }) %>
        </nav>

        <div class="admin-sidebar-footer">
          <div class="admin-user-card">
            <% if (typeof user !== 'undefined' && user) { %>
              <strong><%= user.name %></strong>
              <span><%= user.email || 'Administrador' %></span>
            <% } else { %>
              <strong>Acesso administrativo</strong>
              <span>Entre para continuar.</span>
            <% } %>
          </div>

          <div class="admin-sidebar-actions">
            <a href="/" target="_blank" class="admin-btn-secondary"><i class="fas fa-arrow-up-right-from-square"></i><span>Ver site</span></a>
            <% if (typeof user !== 'undefined' && user) { %>
              <a href="/auth/logout" class="admin-btn-danger"><i class="fas fa-right-from-bracket"></i><span>Sair</span></a>
            <% } %>
          </div>
        </div>
      </div>
    </aside>

    <main class="admin-main">
      <div class="admin-mobile-bar">
        <strong>Admin</strong>
        <a href="/" target="_blank" class="admin-btn-ghost"><i class="fas fa-arrow-up-right-from-square"></i><span>Site</span></a>
      </div>

      <div class="admin-topbar">
        <div class="admin-topbar-card" style="flex:1;">
          <div>
            <div class="admin-kicker">Operacao e conteudo</div>
            <strong style="font-size:1.15rem;"><%= typeof title !== 'undefined' ? title : 'Painel de controle' %></strong>
          </div>
          <div style="color:var(--admin-muted);font-size:14px;">Controle visual, publicacoes e atendimento em um unico fluxo.</div>
        </div>
      </div>

      <%- body %>

      <div class="admin-footer">&copy; <%= new Date().getFullYear() %> Agencia de Emprego. Painel administrativo renovado.</div>
    </main>
  </div>

  <div id="admin-lightbox" class="admin-lightbox">
    <button id="admin-lightbox-close" class="admin-lightbox-close" type="button"><i class="fas fa-times"></i></button>
    <img id="admin-lightbox-image" src="" alt="Pre-visualizacao">
  </div>

  <script src="/js/admin-professional.js"></script>
</body>
</html>
