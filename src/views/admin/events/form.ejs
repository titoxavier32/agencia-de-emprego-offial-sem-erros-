<div class="admin-page">
  <section class="admin-form-wrap">
    <div class="admin-section-head">
      <div>
        <h2><%= title %></h2>
        <p>Cadastre eventos e, se quiser, use este mesmo item como noticia/slide do banner principal da home.</p>
      </div>
      <a href="/admin/events" class="admin-btn-ghost">Voltar</a>
    </div>

    <% if (typeof formError !== 'undefined' && formError) { %>
      <div class="admin-alert"><%= formError %></div>
    <% } %>

    <form action="<%= event ? '/admin/events/editar/' + event.id : '/admin/events/novo' %>" method="POST" enctype="multipart/form-data" class="admin-form">
      <div class="admin-form-row">
        <label for="title">Titulo</label>
        <input type="text" id="title" name="title" value="<%= event ? event.title : '' %>" required placeholder="Ex: Feira de Empregabilidade 2026">
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="date">Data</label>
          <input type="date" id="date" name="date" value="<%= event && event.date ? event.date : '' %>">
        </div>
        <div class="admin-form-row">
          <label for="time">Horario</label>
          <input type="text" id="time" name="time" value="<%= event ? event.time : '' %>" placeholder="Ex: 19:00">
        </div>
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="location">Local</label>
          <input type="text" id="location" name="location" value="<%= event ? event.location : '' %>" placeholder="Ex: Auditorio Central">
        </div>
        <div class="admin-form-row">
          <label for="category">Categoria</label>
          <input type="text" id="category" name="category" value="<%= event ? event.category : '' %>" placeholder="Ex: Noticia, Feira, Workshop">
        </div>
      </div>

      <div class="admin-form-row">
        <label for="address">Endereco</label>
        <input type="text" id="address" name="address" value="<%= event ? event.address : '' %>" placeholder="Ex: Av. Sete de Setembro, 1000 - Centro">
      </div>

      <div class="admin-form-row">
        <label for="organizer">Organizado por</label>
        <input type="text" id="organizer" name="organizer" value="<%= event ? event.organizer : '' %>" placeholder="Ex: Agencia de Emprego">
      </div>

      <div class="admin-form-row">
        <label for="description">Descricao completa</label>
        <textarea id="description" name="description" rows="5" required><%= event ? event.description : '' %></textarea>
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="isFree">Tipo</label>
          <select id="isFree" name="isFree">
            <option value="on" <%= !event || event.isFree ? 'selected' : '' %>>Gratuito</option>
            <option value="off" <%= event && !event.isFree ? 'selected' : '' %>>Pago</option>
          </select>
        </div>
        <div id="priceRow" class="admin-form-row <%= (event && !event.isFree) ? '' : 'hidden' %>">
          <label for="price">Valor</label>
          <input type="text" id="price" name="price" value="<%= event ? event.price : '' %>" placeholder="Ex: R$ 50,00">
        </div>
      </div>

      <div class="admin-form-row">
        <label for="link">Link principal</label>
        <input type="url" id="link" name="link" value="<%= event ? event.link : '' %>" placeholder="https://site.com/noticia-ou-inscricao">
      </div>

      <div class="admin-form-grid">
        <div class="admin-form-row">
          <label for="image">Foto do banner <% if (event && event.image) { %><span class="admin-form-help">(atual mantida)</span><% } %></label>
          <input type="file" id="image" name="image" accept="image/*">
        </div>
        <div class="admin-form-row">
          <label for="status">Status</label>
          <select id="status" name="status">
            <option value="ativo" <%= !event || event.status === 'ativo' ? 'selected' : '' %>>Ativo / Publicado</option>
            <option value="encerrado" <%= event && event.status === 'encerrado' ? 'selected' : '' %>>Encerrado</option>
            <option value="cancelado" <%= event && event.status === 'cancelado' ? 'selected' : '' %>>Cancelado</option>
          </select>
        </div>
      </div>

      <div class="admin-structured-block">
        <div class="admin-section-head">
          <div>
            <h2>Banner principal da home</h2>
            <p>Ative abaixo para transformar este item em um slide/noticia rotativa do banner principal.</p>
          </div>
        </div>

        <div class="admin-form-grid">
          <div class="admin-form-row admin-form-checkbox admin-form-checkbox-card">
            <label>
              <input type="checkbox" name="showInHero" <%= event && event.showInHero ? 'checked' : '' %>>
              <span>Exibir no banner principal da home</span>
            </label>
          </div>
          <div class="admin-form-row">
            <label for="heroOrder">Ordem do slide</label>
            <input type="number" id="heroOrder" name="heroOrder" min="0" max="99" value="<%= event && event.heroOrder !== undefined ? event.heroOrder : 0 %>">
          </div>
        </div>

        <div class="admin-form-row">
          <label for="heroKicker">Linha superior curta</label>
          <input type="text" id="heroKicker" name="heroKicker" value="<%= event && event.heroKicker ? event.heroKicker : '' %>" placeholder="Ex: Plataforma em destaque">
        </div>

        <div class="admin-form-row">
          <label for="heroSummary">Resumo curto para o banner</label>
          <textarea id="heroSummary" name="heroSummary" rows="3" placeholder="Texto curto e elegante para aparecer no banner, sem excesso de informacao."><%= event && event.heroSummary ? event.heroSummary : '' %></textarea>
        </div>

        <div class="admin-form-row">
          <label for="heroButtonLabel">Texto do botao do slide</label>
          <input type="text" id="heroButtonLabel" name="heroButtonLabel" value="<%= event && event.heroButtonLabel ? event.heroButtonLabel : '' %>" placeholder="Ex: Saiba mais">
        </div>
      </div>

      <% if (event && event.image) { %>
        <div class="admin-image-preview">
          <img src="/uploads/<%= event.image %>" alt="Imagem atual">
        </div>
      <% } %>

      <div class="admin-actions">
        <button type="submit" class="admin-btn">Salvar item</button>
      </div>
    </form>
  </section>
</div>

<script>
  const isFreeSelect = document.getElementById('isFree');
  const priceRow = document.getElementById('priceRow');

  if (isFreeSelect && priceRow) {
    const syncPrice = () => {
      priceRow.style.display = isFreeSelect.value === 'off' ? 'block' : 'none';
    };

    isFreeSelect.addEventListener('change', syncPrice);
    syncPrice();
  }
</script>
